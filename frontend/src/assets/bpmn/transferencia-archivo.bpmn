<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  id="Definitions_4"
                  targetNamespace="http://siade.alcaldia.gov.co/bpmn">

  <bpmn:process id="TransferenciaArchivo" name="Transferencia al Archivo Central" isExecutable="true">

    <bpmn:startEvent id="inicio" name="Dependencia identifica documentos a transferir">
      <bpmn:outgoing>flujo1</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:userTask id="prepararInventario" name="Preparar inventario documental&#10;ANS: 5 días hábiles">
      <bpmn:incoming>flujo1</bpmn:incoming>
      <bpmn:outgoing>flujo2</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:userTask id="archivoRevisa" name="Archivo Central revisa y valida&#10;ANS: 3 días hábiles">
      <bpmn:incoming>flujo2</bpmn:incoming>
      <bpmn:outgoing>flujo3</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="valido" name="¿Inventario válido?">
      <bpmn:incoming>flujo3</bpmn:incoming>
      <bpmn:outgoing>flujo4si</bpmn:outgoing>
      <bpmn:outgoing>flujo4no</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:userTask id="corregirInventario" name="Corregir y reenviar inventario">
      <bpmn:incoming>flujo4no</bpmn:incoming>
      <bpmn:outgoing>flujoVolver</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:userTask id="transferirFisico" name="Transferir documentos físicamente">
      <bpmn:incoming>flujo4si</bpmn:incoming>
      <bpmn:outgoing>flujo5</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:serviceTask id="registrarSistema" name="Sistema registra transferencia en SIADE">
      <bpmn:incoming>flujo5</bpmn:incoming>
      <bpmn:outgoing>flujo6</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:serviceTask id="actualizarTRD" name="Sistema actualiza estado en TRD">
      <bpmn:incoming>flujo6</bpmn:incoming>
      <bpmn:outgoing>flujo7</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:serviceTask id="notificarDependencia" name="Sistema notifica a la dependencia">
      <bpmn:incoming>flujo7</bpmn:incoming>
      <bpmn:outgoing>flujoFin</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:endEvent id="fin" name="Fin — Transferencia completada">
      <bpmn:incoming>flujoFin</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="flujo1" sourceRef="inicio" targetRef="prepararInventario"/>
    <bpmn:sequenceFlow id="flujo2" sourceRef="prepararInventario" targetRef="archivoRevisa"/>
    <bpmn:sequenceFlow id="flujo3" sourceRef="archivoRevisa" targetRef="valido"/>
    <bpmn:sequenceFlow id="flujo4si" name="Sí" sourceRef="valido" targetRef="transferirFisico"/>
    <bpmn:sequenceFlow id="flujo4no" name="No" sourceRef="valido" targetRef="corregirInventario"/>
    <bpmn:sequenceFlow id="flujoVolver" sourceRef="corregirInventario" targetRef="archivoRevisa"/>
    <bpmn:sequenceFlow id="flujo5" sourceRef="transferirFisico" targetRef="registrarSistema"/>
    <bpmn:sequenceFlow id="flujo6" sourceRef="registrarSistema" targetRef="actualizarTRD"/>
    <bpmn:sequenceFlow id="flujo7" sourceRef="actualizarTRD" targetRef="notificarDependencia"/>
    <bpmn:sequenceFlow id="flujoFin" sourceRef="notificarDependencia" targetRef="fin"/>
  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_4">
    <bpmndi:BPMNPlane id="BPMNPlane_4" bpmnElement="TransferenciaArchivo">
      <bpmndi:BPMNShape id="inicio_di" bpmnElement="inicio"><dc:Bounds x="152" y="82" width="36" height="36"/></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="prepararInventario_di" bpmnElement="prepararInventario"><dc:Bounds x="240" y="60" width="120" height="80"/></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="archivoRevisa_di" bpmnElement="archivoRevisa"><dc:Bounds x="410" y="60" width="120" height="80"/></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="valido_di" bpmnElement="valido" isMarkerVisible="true"><dc:Bounds x="585" y="75" width="50" height="50"/></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="corregirInventario_di" bpmnElement="corregirInventario"><dc:Bounds x="560" y="200" width="120" height="80"/></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="transferirFisico_di" bpmnElement="transferirFisico"><dc:Bounds x="690" y="60" width="120" height="80"/></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="registrarSistema_di" bpmnElement="registrarSistema"><dc:Bounds x="860" y="60" width="120" height="80"/></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="actualizarTRD_di" bpmnElement="actualizarTRD"><dc:Bounds x="1030" y="60" width="120" height="80"/></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="notificarDependencia_di" bpmnElement="notificarDependencia"><dc:Bounds x="1200" y="60" width="120" height="80"/></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="fin_di" bpmnElement="fin"><dc:Bounds x="1372" y="82" width="36" height="36"/></bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="flujo1_di" bpmnElement="flujo1"><di:waypoint x="188" y="100"/><di:waypoint x="240" y="100"/></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="flujo2_di" bpmnElement="flujo2"><di:waypoint x="360" y="100"/><di:waypoint x="410" y="100"/></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="flujo3_di" bpmnElement="flujo3"><di:waypoint x="530" y="100"/><di:waypoint x="585" y="100"/></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="flujo4si_di" bpmnElement="flujo4si"><di:waypoint x="635" y="100"/><di:waypoint x="690" y="100"/></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="flujo4no_di" bpmnElement="flujo4no"><di:waypoint x="610" y="125"/><di:waypoint x="610" y="200"/></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="flujoVolver_di" bpmnElement="flujoVolver"><di:waypoint x="560" y="240"/><di:waypoint x="470" y="240"/><di:waypoint x="470" y="140"/></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="flujo5_di" bpmnElement="flujo5"><di:waypoint x="810" y="100"/><di:waypoint x="860" y="100"/></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="flujo6_di" bpmnElement="flujo6"><di:waypoint x="980" y="100"/><di:waypoint x="1030" y="100"/></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="flujo7_di" bpmnElement="flujo7"><di:waypoint x="1150" y="100"/><di:waypoint x="1200" y="100"/></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="flujoFin_di" bpmnElement="flujoFin"><di:waypoint x="1320" y="100"/><di:waypoint x="1372" y="100"/></bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
